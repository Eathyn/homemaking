.container {
	display: flex;
	flex-direction: column;
	height: 100%;
}

.tabs {
	display: flex;
	height: 90rpx;
	box-sizing: border-box;
}

.tab-item {
	flex: 1;
	display: flex;
	flex-direction: column;
	align-items: center;
}

.item-label {
	color: #888888;
	white-space: nowrap;
}

.active-tab {
	color: #333333;
	font-weight: bold;
}

.divider {
	width: 50rpx;
	height: 6rpx;
	margin-top: 10rpx;
	background-color: #f3d066;
}

.category {
	padding: 30rpx 0 30rpx 30rpx;
}

.category-swiper-item {
	border-radius: 20rpx;
	width: 300rpx;
	height: 150rpx;
	background-image: linear-gradient(to right, #e68d44, #eb6d59);
}

.category-name {
	position: absolute;
	top: 20rpx;
	left: 20rpx;
	color: #fff;
}
